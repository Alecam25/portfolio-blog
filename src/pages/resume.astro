---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="ProjectLog | Resume"
  description="Preview and download Alessandro's resume."
>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="container-custom py-20 flex-1">

      <!-- Header Section -->
      <div class="mb-12 flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="mb-3 text-sm uppercase tracking-[0.3em] text-cyan-400">Curriculum Vitae</p>
          <h1 class="mb-4 text-4xl font-bold md:text-5xl">Alessandro Campos</h1>
          <p class="max-w-xl text-lg leading-8 text-slate-300">
            Systems Engineering Student · Web & Database Developer
          </p>

          <!-- Contact chips -->
          <div class="mt-5 flex flex-wrap gap-3 text-sm text-slate-300">
            <a
              href="mailto:Alessandro.cam.2005@gmail.com"
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 transition hover:border-cyan-400 hover:text-cyan-400"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5A2.25 2.25 0 002.25 6.75m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.909A2.25 2.25 0 012.25 6.993V6.75" />
              </svg>
              Alessandro.cam.2005@gmail.com
            </a>

            <a
              href="https://github.com/Alecam25"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 transition hover:border-cyan-400 hover:text-cyan-400"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.605-3.369-1.343-3.369-1.343-.454-1.157-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.893 1.53 2.341 1.088 2.91.832.091-.647.35-1.088.636-1.338-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.943.359.31.678.921.678 1.857 0 1.34-.012 2.421-.012 2.75 0 .269.18.58.688.481A10.019 10.019 0 0022 12.017C22 6.484 17.523 2 12 2z" />
              </svg>
              GitHub
            </a>

            <a
              href="https://www.linkedin.com/in/alessandro-campos-bb8243351/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 transition hover:border-cyan-400 hover:text-cyan-400"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.11 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4V24h-4V8zm7 0h3.8v2.2h.1c.53-1 1.83-2.2 3.77-2.2 4.03 0 4.78 2.65 4.78 6.1V24h-4v-7.3c0-1.74-.03-3.98-2.42-3.98-2.42 0-2.8 1.89-2.8 3.85V24h-4V8z"/>
              </svg>
              LinkedIn
            </a>

            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              Costa Rica
            </span>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="flex shrink-0 flex-wrap gap-3">
          <a
            href="/resume.pdf"
            download
            class="inline-flex items-center gap-2 rounded-xl bg-cyan-400 px-5 py-3 font-semibold text-black transition hover:opacity-90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download PDF
          </a>

          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-5 py-3 font-semibold text-white transition hover:border-cyan-400 hover:text-cyan-400"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Open in Tab
          </a>
        </div>
      </div>

      <!-- Skills highlight bar -->
      <div class="mb-8 rounded-2xl border border-white/10 bg-white/5 p-5">
        <p class="mb-4 text-xs uppercase tracking-[0.25em] text-slate-400">Core Skills</p>
        <div class="flex flex-wrap gap-2">
          {["SQL", "PHP", "HTML5", "CSS3", "JavaScript", "MySQL", "Astro", "TypeScript", "Tailwind CSS", "Responsive Design", "Git", "REST APIs"].map((skill) => (
            <span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm font-medium text-cyan-300">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- PDF Viewer — desktop only -->
      <div class="hidden md:block">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-black/40">
          <!-- Viewer header bar -->
          <div class="flex items-center justify-between border-b border-white/10 bg-black/30 px-5 py-3">
            <div class="flex items-center gap-3 text-sm text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="font-medium text-slate-300">resume.pdf</span>
              <span class="text-slate-500">· Alessandro Campos</span>
            </div>
            <a
              href="/resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs text-slate-400 transition hover:text-cyan-400"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
              </svg>
              Full screen
            </a>
          </div>

          <iframe
            src="/resume.pdf"
            class="h-[85vh] w-full"
            title="Alessandro Campos Resume"
          ></iframe>
        </div>
      </div>

      <!-- Mobile fallback — shown only on small screens -->
      <div class="md:hidden">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
          <div class="mb-5 flex justify-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-full border border-cyan-400/30 bg-cyan-400/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
          </div>
          <h2 class="mb-2 text-xl font-semibold">PDF Preview</h2>
          <p class="mb-6 text-slate-400">
            Preview is not available on mobile. Download the PDF or open it in a new tab to view it.
          </p>
          <div class="flex flex-col gap-3">
            <a
              href="/resume.pdf"
              download
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-cyan-400 px-5 py-3 font-semibold text-black transition hover:opacity-90"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download PDF
            </a>
            <a
              href="/resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 px-5 py-3 font-semibold text-white transition hover:border-cyan-400 hover:text-cyan-400"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Open in Tab
            </a>
          </div>
        </div>
      </div>

    </main>

    <Footer />
  </div>
</BaseLayout>