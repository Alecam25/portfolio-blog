---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="ProjectLog | About"
  description="Learn more about Alessandro, a Systems Engineering student at UTC focused on web development, databases and practical software solutions."
>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">

      <!-- Hero -->
      <section class="container-custom py-24 md:py-32">
        <div class="max-w-5xl">
          <p class="mb-5 text-sm uppercase tracking-[0.3em] text-cyan-400">About Me</p>

          <h1 class="max-w-4xl text-4xl font-bold leading-tight text-white md:text-5xl md:leading-tight">
            Systems Engineering Student Focused on Building Practical, Reliable and User-Oriented Digital Solutions
          </h1>

          <p class="mt-8 max-w-3xl text-lg leading-9 text-slate-300">
            I'm a Systems Engineering student at the Universidad Tecnológica Costarricense (UTC),
            graduating in September 2025. I have a strong interest in web development, databases
            and software solutions that solve real-world problems, and I'm actively looking for
            internship or junior developer opportunities where I can keep growing professionally.
          </p>

          <!-- Availability badge -->
          <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-emerald-400/30 bg-emerald-400/10 px-4 py-2 text-sm font-medium text-emerald-300">
            <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
            Available for internships & junior roles
          </div>
        </div>
      </section>

      <!-- Profile + What I bring -->
      <section class="container-custom pb-12 md:pb-16">
        <div class="grid gap-8 lg:grid-cols-2">
          <article class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition duration-300 hover:border-cyan-400/40 hover:bg-white/[0.07] md:p-10">
            <h2 class="mb-5 text-2xl font-semibold text-white">Professional Profile</h2>
            <p class="leading-9 text-slate-300">
              I enjoy working on projects that combine front-end structure, back-end logic and
              database organization. My academic background has strengthened my ability to analyze
              requirements, solve technical problems and create systems with a practical purpose.
            </p>
            <p class="mt-5 leading-9 text-slate-300">
              I'm especially interested in opportunities involving web applications, data-driven
              systems and software projects that require both technical thinking and continuous
              learning. I work well in collaborative environments and adapt quickly to new tools
              and workflows.
            </p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition duration-300 hover:border-cyan-400/40 hover:bg-white/[0.07] md:p-10">
            <h2 class="mb-5 text-2xl font-semibold text-white">What I Bring</h2>
            <ul class="space-y-4 text-slate-300">
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-cyan-400"></span>
                <span>Strong foundation in SQL, PHP, HTML, CSS and JavaScript</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-cyan-400"></span>
                <span>Experience building full-stack web applications with real-world use cases</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-cyan-400"></span>
                <span>Interest in cybersecurity and secure software development practices</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-cyan-400"></span>
                <span>B2 English level — comfortable reading documentation and communicating in professional environments</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-cyan-400"></span>
                <span>Fast learner with a problem-solving mindset and attention to usability</span>
              </li>
            </ul>
          </article>
        </div>
      </section>

      <!-- Education & Courses -->
      <section class="container-custom py-12 md:py-16">
        <p class="mb-3 text-sm uppercase tracking-[0.3em] text-cyan-400">Education & Training</p>
        <h2 class="mb-10 text-3xl font-bold">Academic Background</h2>

        <div class="space-y-5">

          <!-- UTC -->
          <div class="flex gap-6 rounded-2xl border border-white/10 bg-white/5 p-7 transition hover:border-cyan-400/40 hover:bg-white/[0.07]">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-400/30 bg-cyan-400/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path d="M12 14l9-5-9-5-9 5 9 5z" />
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">Bachelor's in Systems Engineering</h3>
                  <p class="text-slate-400">Universidad Tecnológica Costarricense (UTC)</p>
                </div>
                <div class="text-right">
                  <span class="rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-1 text-xs font-medium text-emerald-300">
                    Graduating Sep 2025
                  </span>
                </div>
              </div>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Comprehensive program covering software development, databases, systems analysis,
                networking and software engineering principles. Focus on practical, real-world application development.
              </p>
            </div>
          </div>

          <!-- Cybersecurity course -->
          <div class="flex gap-6 rounded-2xl border border-white/10 bg-white/5 p-7 transition hover:border-cyan-400/40 hover:bg-white/[0.07]">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-400/30 bg-cyan-400/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">Cybersecurity Course</h3>
                  <p class="text-slate-400">VLAcademy · Online</p>
                </div>
                <span class="rounded-full border border-yellow-400/30 bg-yellow-400/10 px-3 py-1 text-xs font-medium text-yellow-300">
                  In Progress
                </span>
              </div>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Covering network security, threat detection, vulnerability assessment and
                secure development practices for web applications.
              </p>
            </div>
          </div>

          <!-- English course -->
          <div class="flex gap-6 rounded-2xl border border-white/10 bg-white/5 p-7 transition hover:border-cyan-400/40 hover:bg-white/[0.07]">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-400/30 bg-cyan-400/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">English Course · B2 Level</h3>
                  <p class="text-slate-400">VLAcademy · Online</p>
                </div>
                <span class="rounded-full border border-yellow-400/30 bg-yellow-400/10 px-3 py-1 text-xs font-medium text-yellow-300">
                  In Progress
                </span>
              </div>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Currently at B2 level — comfortable reading technical documentation, writing
                professional emails and communicating in English-speaking work environments.
              </p>
            </div>
          </div>

        </div>
      </section>

      <!-- Languages + Stack + Goal -->
      <section class="container-custom py-12 md:py-16">
        <div class="grid gap-8 lg:grid-cols-3">

          <article class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition duration-300 hover:border-cyan-400/40 hover:bg-white/[0.07] md:p-10 lg:col-span-2">
            <h2 class="mb-5 text-2xl font-semibold text-white">Career Goal</h2>
            <p class="leading-9 text-slate-300">
              I'm looking for internship or entry-level opportunities where I can apply my
              technical knowledge, grow as a developer and contribute to real projects.
              I want to work in environments where collaboration, continuous improvement
              and practical problem-solving are valued.
            </p>
            <p class="mt-5 leading-9 text-slate-300">
              My interest in cybersecurity also drives me to write cleaner, more secure code
              and think critically about how systems can be built more safely from the ground up.
            </p>
          </article>

          <div class="space-y-6">
            <article class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition duration-300 hover:border-cyan-400/40 hover:bg-white/[0.07]">
              <h2 class="mb-4 text-xl font-semibold text-white">Languages</h2>
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <span class="text-slate-300">Spanish</span>
                  <span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-2.5 py-1 text-xs font-medium text-cyan-300">Native</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-slate-300">English</span>
                  <span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-2.5 py-1 text-xs font-medium text-cyan-300">B2</span>
                </div>
              </div>
            </article>

            <article class="rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition duration-300 hover:border-cyan-400/40 hover:bg-white/[0.07]">
              <h2 class="mb-4 text-xl font-semibold text-white">Main Stack</h2>
              <div class="flex flex-wrap gap-2">
                {["SQL", "PHP", "HTML", "CSS", "JavaScript", "Astro", "TypeScript", "Tailwind CSS", "MySQL", "Git"].map((s) => (
                  <span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm font-medium text-cyan-300">{s}</span>
                ))}
              </div>
            </article>
          </div>

        </div>
      </section>

      <!-- CTA -->
      <section class="container-custom pb-24 md:pb-32">
        <div class="rounded-3xl border border-white/10 bg-white/5 p-10 text-center md:p-16">
          <p class="mb-4 text-sm uppercase tracking-[0.3em] text-cyan-400">Let's connect</p>
          <h2 class="mb-4 text-3xl font-bold">Want to work together?</h2>
          <p class="mx-auto mb-10 max-w-xl text-lg leading-8 text-slate-300">
            I'm actively looking for opportunities. Check my resume, explore my projects
            or send me a message directly.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="/contact"
              class="rounded-xl bg-cyan-400 px-6 py-3 font-semibold text-black transition hover:opacity-90"
            >
              Contact Me
            </a>
            <a
              href="/resume"
              class="rounded-xl border border-white/20 px-6 py-3 text-white transition hover:border-cyan-400 hover:text-cyan-400"
            >
              View Resume
            </a>
            <a
              href="/projects"
              class="rounded-xl border border-white/20 px-6 py-3 text-white transition hover:border-cyan-400 hover:text-cyan-400"
            >
              See Projects
            </a>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </div>
</BaseLayout>